<% content_for :title, "New story — #{@city.name}" %>

<div class="max-w-2xl mx-auto">
  <p class="text-sm text-slate-500 mb-1">New story in</p>
  <h1 class="text-2xl font-bold mb-6"><%= link_to @city.name, city_path(@city), class: "hover:text-indigo-600" %></h1>

  <div class="card p-6">
    <%= render "posts/form", post: @post %>
  </div>
</div>
