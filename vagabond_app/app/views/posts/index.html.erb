<% content_for :title, "Stories from #{@city.name}" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Stories from <%= link_to @city.name, city_path(@city), class: "hover:text-indigo-600" %></h1>
  <% if logged_in? %>
    <%= link_to "Write a story", new_city_post_path(@city), class: "btn-primary" %>
  <% end %>
</div>

<% if @posts.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%= render partial: "posts/post_card", collection: @posts, as: :post %>
  </div>
<% else %>
  <div class="card p-10 text-center text-slate-500">No stories yet.</div>
<% end %>
