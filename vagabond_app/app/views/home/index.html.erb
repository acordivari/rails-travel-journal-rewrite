<% content_for :title, "Vagabond — travel stories, city by city" %>

<section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-indigo-600 to-sky-500 text-white px-6 sm:px-10 py-16 mb-12">
  <div class="max-w-2xl">
    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight">Travel stories, city by city.</h1>
    <p class="mt-4 text-lg text-indigo-100">
      Discover what it's really like to visit a place — written by people who've been there.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <%= link_to "Browse all cities", cities_path, class: "btn bg-white text-indigo-700 hover:bg-indigo-50" %>
      <% unless logged_in? %>
        <%= link_to "Join Vagabond", new_user_path, class: "btn bg-indigo-700/40 text-white hover:bg-indigo-700/60" %>
      <% end %>
    </div>
  </div>
</section>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-2xl font-bold text-slate-900">Popular destinations</h2>
  <%= link_to "View all →", cities_path, class: "text-indigo-600 hover:underline font-medium" %>
</div>

<% if @featured_cities.any? %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
    <%= render partial: "cities/city_card", collection: @featured_cities, as: :city %>
  </div>
<% else %>
  <div class="card p-10 text-center text-slate-500 mb-12">No cities yet.</div>
<% end %>

<% if @recent_posts.any? %>
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-slate-900">Latest stories</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%= render partial: "posts/post_card", collection: @recent_posts, as: :post, locals: { show_city: true } %>
  </div>
<% end %>
