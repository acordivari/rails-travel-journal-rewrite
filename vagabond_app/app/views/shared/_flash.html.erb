<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <div data-controller="flash"
       data-flash-dismiss-after-value="5000"
       class="mb-4 flex items-start justify-between gap-3 rounded-xl border px-4 py-3 text-sm <%= flash_classes(type) %>">
    <p><%= message %></p>
    <button type="button" data-action="flash#dismiss" class="shrink-0 opacity-60 hover:opacity-100" aria-label="Dismiss">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
<% end %>
