<%= render "shared/form_errors", record: user %>

<%= form_with model: user, class: "space-y-5" do |f| %>
  <div>
    <%= f.label :name, class: "field-label" %>
    <%= f.text_field :name, class: "field-input", autofocus: true %>
  </div>

  <div>
    <%= f.label :email, class: "field-label" %>
    <%= f.email_field :email, class: "field-input", autocomplete: "email" %>
  </div>

  <div>
    <%= f.label :current_city, "Where are you now?", class: "field-label" %>
    <%= f.text_field :current_city, class: "field-input", placeholder: "Optional" %>
  </div>

  <div>
    <%= f.label :password, class: "field-label" %>
    <%= f.password_field :password, class: "field-input", autocomplete: (user.persisted? ? "new-password" : "new-password") %>
    <% if user.persisted? %>
      <p class="mt-1 text-xs text-slate-500">Leave blank to keep your current password.</p>
    <% end %>
  </div>

  <div data-controller="preview">
    <%= f.label :avatar, "Profile photo (optional)", class: "field-label" %>
    <%= f.file_field :avatar, accept: "image/*", class: "field-input", data: { preview_target: "input", action: "preview#show" } %>
    <img data-preview-target="image" class="mt-3 hidden rounded-full w-20 h-20 object-cover" alt="Preview">
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit(user.persisted? ? "Save profile" : "Create account", class: "btn-primary") %>
    <%= link_to "Cancel", (user.persisted? ? user_path(user) : root_path), class: "btn-secondary" %>
  </div>
<% end %>
