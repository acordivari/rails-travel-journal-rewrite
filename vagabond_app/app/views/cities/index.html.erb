<% content_for :title, "Browse cities — Vagabond" %>

<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-8">
  <div>
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Browse cities</h1>
    <p class="mt-1 text-slate-500"><%= pluralize(@cities.length, "destination") %> to explore.</p>
  </div>
  <% if current_user&.admin? %>
    <%= link_to "Add a city", new_city_path, class: "btn-primary" %>
  <% end %>
</div>

<% if @cities.any? %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <%= render partial: "cities/city_card", collection: @cities, as: :city %>
  </div>
<% else %>
  <div class="card p-10 text-center text-slate-500">
    No cities yet.<% if current_user&.admin? %> <%= link_to "Add the first one", new_city_path, class: "text-indigo-600 hover:underline" %>.<% end %>
  </div>
<% end %>
