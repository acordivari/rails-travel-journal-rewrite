<% content_for :title, "Add a city — Vagabond" %>

<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold mb-6">Add a city</h1>

  <div class="card p-6">
    <%= render "shared/form_errors", record: @city %>

    <%= form_with model: @city, class: "space-y-5" do |f| %>
      <div>
        <%= f.label :name, class: "field-label" %>
        <%= f.text_field :name, class: "field-input", placeholder: "e.g. Lisbon", autofocus: true %>
      </div>

      <div data-controller="preview">
        <%= f.label :image, "Cover image", class: "field-label" %>
        <%= f.file_field :image, accept: "image/*", class: "field-input", data: { preview_target: "input", action: "preview#show" } %>
        <img data-preview-target="image" class="mt-3 hidden rounded-lg max-h-48 object-cover" alt="Preview">
      </div>

      <div class="flex gap-3 pt-2">
        <%= f.submit "Create city", class: "btn-primary" %>
        <%= link_to "Cancel", cities_path, class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
